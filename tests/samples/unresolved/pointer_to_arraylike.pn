fn main() -> u8
{
	var buffer: [3]u8 = [20, 32, 0x00];
	var x: &[]u8 = &buffer;
	var alternative: [4]u8 = [0, 0, 0, 0];
	&x = &alternative;
	alternative[2] = 200;
	var result: u8 = x[2];

	// The above looks reasonable, but then doesn't this allow the following?
	var y: &&[]u8 = &&x;
	foo(&&y);

	return: result
}

fn foo(data: &&[]u8);
