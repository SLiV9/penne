// C and Rust also have separate namespaces, so maybe not that strange.

// Namespace 1: types
struct foo
{
  // Namespace 2: members (separate sub-namespace for each struct))
  foo: i32
}

// Namespace 3: constants (shadowed by variables)
const foo: i32 = 1;
const bar: i32 = foo;

// Namespace 4: functions
// (This being a separate namespace is dubious; I might need to revert it
// if I introduce function pointers at some point.)
fn foo(
  // Namespace 5: variables; level 1, inside function
  foo: &foo
)
{
  // Can't use foo here as a constant since it is shadowed by the parameter.
  if foo.foo == bar
    goto foo;
  foo.foo = 2;
  // Namespace 4: labels; always within one function body
  // Only namespace that isn't associated with types.
  foo:
}
